# Environment variables template for local development.
#
# Copy this file to secrets/.env.dev and fill in the missing values:
#   cp secrets/.env.example secrets/.env.dev
#
# The defaults below match the local docker compose setup (docker/compose.dev.yaml)
# and are safe to commit. Secrets must be filled in locally and never committed.

# --- Django core --------------------------------------------------------------
# Environment name: dev | test | prod. Keep "dev" for local development.
ENVIRONMENT=dev
# Toggles Django debug mode. Defaults to True for dev/test if unset.
DEBUG=True
# Django secret key. Any non-empty string works locally; use a strong random
# value in production.
SECRET_KEY=django-insecure-changeme
# Host the app is served on. Used for ALLOWED_HOSTS / CSRF trusted origins.
APPLICATION_DOMAIN=localhost

# --- Database -----------------------------------------------------------------
# These match the "db" service in docker/compose.dev.yaml.
DATABASE_NAME=ultihub
DATABASE_USER=ultihub
DATABASE_PASSWORD=password
# Use "db" when running inside docker compose; "localhost" when running locally.
DATABASE_HOST=db

# --- Google OAuth -------------------------------------------------------------
# Credentials from a Google Cloud OAuth 2.0 client (the only sign-in method).
# Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# --- Email (SMTP via Gmail) ---------------------------------------------------
# Gmail account and app password used to send notification emails.
EMAIL_HOST_USER=your-gmail-address-here
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
# Recipient address for member-related notifications.
MEMBER_NOTIFICATION_EMAIL=member-notifications@example.com

# --- Original evidence system -------------------------------------------------
# Credentials for the legacy evidence system the app integrates with.
ORIGINAL_EVIDENCE_LOGIN=
ORIGINAL_EVIDENCE_PASSWORD=

# --- Fakturoid (invoicing) ----------------------------------------------------
# OAuth client credentials and account slug from https://app.fakturoid.cz
# Can be left empty for local development if invoicing is not exercised.
FAKTUROID_CLIENT_ID=
FAKTUROID_CLIENT_SECRET=
FAKTUROID_SLUG=

# --- Dropbox (database backups) -----------------------------------------------
# Dropbox app credentials used by django-dbbackup. Not required for most local
# work; leave empty unless testing backups.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_OAUTH2_REFRESH_TOKEN=

# --- Monitoring (Sentry) ------------------------------------------------------
# Sentry DSN for error reporting. Optional; leave empty to disable.
SENTRY_DSN=

# --- Application settings -----------------------------------------------------
# National team club ID used for international tournament rosters. Defaults to 33.
NATIONAL_TEAM_CLUB_ID=33
